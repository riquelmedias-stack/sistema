<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400.0" prefWidth="700.0" style="-fx-background-color: gray;" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.controller.HistoricoController">

    <children>
      <MenuBar AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <menus>
          <Menu mnemonicParsing="false" text="Inicio">
            <items>
              <MenuItem fx:id="itemSair" mnemonicParsing="false" onAction="#Sair" text="Sair" />
            </items>
          </Menu>
          <Menu mnemonicParsing="false" text="Cadastros">
            <items>
              <MenuItem fx:id="itemUsuarios" mnemonicParsing="false" onAction="#AbrirCadastroUsuario" text="Usuarios" />
              <MenuItem fx:id="itemClientes" mnemonicParsing="false" onAction="#AbrirCadastroClientes" text="Clientes" />
              <MenuItem fx:id="itemProdutos" mnemonicParsing="false" onAction="#AbrirCadastroProdutos" text="Produtos" />
            </items>
          </Menu>
          <Menu mnemonicParsing="false" text="Operações">
            <items>
              <MenuItem fx:id="itemProcessaEstoque" mnemonicParsing="false" text="Processar estoque" />
              <MenuItem fx:id="itemFrente" mnemonicParsing="false" text="Frente de Caixa/PDV" />
            </items>
          </Menu>
        </menus>
      </MenuBar>
      
        <VBox spacing="15.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="40.0">

            <Label style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:white;" text="📜 Histórico de Movimentação" />
            <Label fx:id="lblProd" prefHeight="18.0" prefWidth="450.0" style="-fx-text-fill:#dddddd;" />

            <HBox alignment="CENTER_LEFT" spacing="15">
                <VBox spacing="5">
                    <Label style="-fx-text-fill:#dddddd;" text="Data Início" />
                    <DatePicker fx:id="dataInicio" />
                </VBox>

                <VBox spacing="5">
                    <Label style="-fx-text-fill:#dddddd;" text="Data Final" />
                    <DatePicker fx:id="dataFinal" />
                </VBox>

                <Button fx:id="btnBuscar" style="-fx-background-color:#2196F3; -fx-text-fill:white; -fx-font-weight: bold;" text="Buscar" />
            </HBox>

            <TableView fx:id="tabHistorico" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colID" prefWidth="50" text="ID" />
                    <TableColumn fx:id="colData" prefWidth="150" text="Data" />
                    <TableColumn fx:id="colIdProd" prefWidth="100" text="ID Produto" />
                    <TableColumn fx:id="colNome" prefWidth="150" text="Nome" />
                    <TableColumn fx:id="colTipo" prefWidth="100" text="Tipo" />
                    <TableColumn fx:id="colQuantidade" prefWidth="80" text="Qtd" />
                    <TableColumn fx:id="colUsuario" prefWidth="120" text="Usuário" />
                </columns>
            </TableView>

        </VBox>
    </children>
</AnchorPane>